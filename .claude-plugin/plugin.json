{
  "name": "usage-guard",
  "description": "Halt Claude Code agents at configurable usage thresholds with notifications and snooze/resume via /usage-guard:resume.",
  "author": {
    "name": "Denver Baumgartner",
    "url": "https://github.com/denverbaumgartner"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-usage.sh\"",
            "timeout": 10,
            "statusMessage": "Checking usage limits..."
          }
        ]
      }
    ]
  }
}
